{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-e2d5.up.railway.app/api/:path*"
    },
    {
      "source": "/signal",
      "destination": "https://backend-production-e2d5.up.railway.app/signal"
    },
    {
      "source": "/signal-status",
      "destination": "https://backend-production-e2d5.up.railway.app/signal-status"
    },
    {
      "source": "/email-status",
      "destination": "https://backend-production-e2d5.up.railway.app/email-status"
    },
    {
      "source": "/reset",
      "destination": "https://backend-production-e2d5.up.railway.app/reset"
    },
    {
      "source": "/health",
      "destination": "https://backend-production-e2d5.up.railway.app/health"
    },
    {
      "source": "/((?!data/).*)",
      "destination": "/index.html"
    }
  ]
}
